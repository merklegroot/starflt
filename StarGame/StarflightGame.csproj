<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Raylib-cs" Version="5.0.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="starSystems.json" />
    <EmbeddedResource Include="planets.json" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Fonts\OpenSans.ttf" CopyToOutputDirectory="PreserveNewest" />
    <None Include="Fonts\OpenSans-OFL.txt" CopyToOutputDirectory="PreserveNewest" />
    <None Include="Textures\tiny-spaceships\**\*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
